{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python3 \"${CURSOR_PLUGIN_ROOT}/hooks/guard-sifflet-destructive.py\"",
        "matcher": "sifflet|rm |git rm|mv ",
        "failClosed": true,
        "timeout": 15
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "python3 \"${CURSOR_PLUGIN_ROOT}/hooks/guard-sifflet-destructive.py\"",
        "failClosed": true,
        "timeout": 15
      }
    ]
  }
}
